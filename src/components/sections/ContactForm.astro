---
// ContactForm.astro — client-side submits to /api/contact via fetch
---

<form
  id="contact-form"
  novalidate
  class="space-y-5"
  aria-label="Formulario de contacto"
>
  <!-- Row: nombre + empresa -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <label for="nombre" class="block text-sm text-mid mb-1.5">Nombre completo <span class="text-blue-DEFAULT" aria-hidden="true">*</span></label>
      <input
        id="nombre" name="nombre" type="text"
        required autocomplete="name"
        placeholder="Lorem Ipsum"
        class="w-full bg-white border border-border text-dark text-sm px-3.5 py-2.5 rounded focus:outline-none focus:border-blue-DEFAULT transition-colors"
      />
    </div>
    <div>
      <label for="empresa" class="block text-sm text-mid mb-1.5">Empresa</label>
      <input
        id="empresa" name="empresa" type="text"
        autocomplete="organization"
        placeholder="Consectetur SAS"
        class="w-full bg-white border border-border text-dark text-sm px-3.5 py-2.5 rounded focus:outline-none focus:border-blue-DEFAULT transition-colors"
      />
    </div>
  </div>

  <!-- Row: email + phone -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <label for="email" class="block text-sm text-mid mb-1.5">Correo electrónico <span class="text-blue-DEFAULT" aria-hidden="true">*</span></label>
      <input
        id="email" name="email" type="email"
        required autocomplete="email"
        placeholder="lorem@consectetur.com"
        class="w-full bg-white border border-border text-dark text-sm px-3.5 py-2.5 rounded focus:outline-none focus:border-blue-DEFAULT transition-colors"
      />
    </div>
    <div>
      <label for="telefono" class="block text-sm text-mid mb-1.5">Teléfono</label>
      <input
        id="telefono" name="telefono" type="tel"
        autocomplete="tel"
        placeholder="+57 300 000 0000"
        class="w-full bg-white border border-border text-dark text-sm px-3.5 py-2.5 rounded focus:outline-none focus:border-blue-DEFAULT transition-colors"
      />
    </div>
  </div>

  <!-- Service -->
  <div>
    <label for="servicio" class="block text-sm text-mid mb-1.5">Tipo de servicio requerido <span class="text-blue-DEFAULT" aria-hidden="true">*</span></label>
    <select
      id="servicio" name="servicio"
      required
      class="w-full bg-white border border-border text-dark text-sm px-3.5 py-2.5 rounded focus:outline-none focus:border-blue-DEFAULT transition-colors appearance-none"
    >
      <option value="" disabled selected>Seleccionar...</option>
      <option value="Obra Civil">Obra Civil</option>
      <option value="Estructuras Metálicas">Estructuras Metálicas</option>
      <option value="Metalmecánica Industrial">Metalmecánica Industrial</option>
      <option value="Consultoría de Ingeniería">Consultoría de Ingeniería</option>
      <option value="Otro">Otro</option>
    </select>
  </div>

  <!-- Message -->
  <div>
    <label for="mensaje" class="block text-sm text-mid mb-1.5">Descripción del proyecto <span class="text-blue-DEFAULT" aria-hidden="true">*</span></label>
    <textarea
      id="mensaje" name="mensaje"
      required rows="5"
      placeholder="Lorem ipsum dolor sit amet, consectetur adipiscing elit..."
      class="w-full bg-white border border-border text-dark text-sm px-3.5 py-2.5 rounded focus:outline-none focus:border-blue-DEFAULT transition-colors resize-y"
    ></textarea>
  </div>

  <!-- Status message -->
  <div id="form-status" role="alert" aria-live="polite" class="hidden"></div>

  <!-- Submit -->
  <button
    type="submit"
    id="submit-btn"
    class="w-full bg-blue-600 text-white text-sm font-medium px-6 py-3 rounded hover:bg-blue-hover transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-DEFAULT focus-visible:ring-offset-2 disabled:opacity-60 disabled:cursor-not-allowed"
  >
    Enviar Solicitud
  </button>
</form>

<script>
  const form      = document.getElementById('contact-form')      as HTMLFormElement;
  const statusEl  = document.getElementById('form-status')!;
  const submitBtn = document.getElementById('submit-btn')        as HTMLButtonElement;

  function showStatus(type: 'success' | 'error', message: string) {
    statusEl.className = [
      'p-4 rounded text-sm',
      type === 'success'
        ? 'bg-green-50 text-green-800 border border-green-200'
        : 'bg-red-50 text-red-800 border border-red-200',
    ].join(' ');
    statusEl.textContent = message;
    statusEl.classList.remove('hidden');
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    submitBtn.disabled    = true;
    submitBtn.textContent = 'Enviando...';
    statusEl.classList.add('hidden');

    try {
      const data = Object.fromEntries(new FormData(form));
      const res  = await fetch('/api/contact', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify(data),
      });

      if (res.ok) {
        showStatus('success', '¡Mensaje enviado! Nos pondremos en contacto muy pronto.');
        form.reset();
      } else {
        const body = await res.json().catch(() => ({}));
        showStatus('error', body.message ?? 'Ocurrió un error. Por favor inténtelo de nuevo.');
      }
    } catch {
      showStatus('error', 'No se pudo enviar el mensaje. Revise su conexión e inténtelo de nuevo.');
    } finally {
      submitBtn.disabled    = false;
      submitBtn.textContent = 'Enviar Solicitud';
    }
  });
</script>
