---
import Button from '../ui/Button.astro';

interface Props {
  title?:    string;
  subtitle?: string;
  cta?:      string;
  href?:     string;
}

const {
  title    = '¿Listo para construir algo extraordinario?',
  subtitle = 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Contáctenos hoy.',
  cta      = 'Iniciar Proyecto',
  href     = '/contacto',
} = Astro.props;
---

<section class="bg-dark py-16 md:py-20" aria-labelledby="cta-title">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
    <div>
      <h2 id="cta-title" class="font-head text-2xl md:text-3xl font-bold text-white text-balance">
        {title}
      </h2>
      <p class="text-sm text-gray-400 mt-2">{subtitle}</p>
    </div>
    <a
      href={href}
      class="shrink-0 inline-flex items-center bg-blue-DEFAULT text-white text-sm font-medium px-6 py-3 rounded hover:bg-blue-hover transition-colors duration-150"
    >
      {cta}
    </a>
  </div>
</section>
