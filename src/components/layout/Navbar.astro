---
import { NAV_LINKS, SITE } from '../../data/site';

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 inset-x-0 z-50 bg-white border-b border-border">
  <nav
    aria-label="Navegación principal"
    class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 md:h-[68px] flex items-center justify-between"
  >
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 shrink-0" aria-label="Ir al inicio">
      <img src="/logo.png" alt={`${SITE.name} logo`} class="h-10 w-auto" />
      <span class="hidden sm:inline w-px h-4 bg-border self-center"></span>
      <span class="hidden sm:inline font-mono text-[11px] text-muted tracking-wide">
        {SITE.tagline}
      </span>
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-10" role="list">
      {NAV_LINKS.map(({ href, label }) => {
        const isActive =
          href === '/'
            ? currentPath === '/'
            : currentPath.startsWith(href);
        return (
          <li>
            <a
              href={href}
              class={[
                'text-sm transition-colors duration-150',
                isActive
                  ? 'text-dark font-medium border-b border-blue-DEFAULT pb-0.5'
                  : 'text-muted hover:text-dark',
              ].join(' ')}
              aria-current={isActive ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        );
      })}
    </ul>

    <!-- Desktop CTA -->
    <a
      href="/contacto"
      class="hidden md:inline-flex items-center bg-dark text-white text-sm font-medium px-5 py-2.5 rounded hover:bg-mid transition-colors duration-150"
    >
      Contáctenos
    </a>

    <!-- Mobile hamburger -->
    <button
      id="menu-btn"
      type="button"
      aria-controls="mobile-menu"
      aria-expanded="false"
      aria-label="Abrir menú"
      class="md:hidden p-2 rounded text-mid hover:text-dark hover:bg-off transition-colors"
    >
      <svg id="icon-open"  class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/></svg>
      <svg id="icon-close" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden bg-white border-t border-border"
    role="navigation"
    aria-label="Menú móvil"
  >
    <ul class="px-4 py-4 flex flex-col gap-1" role="list">
      {NAV_LINKS.map(({ href, label }) => {
        const isActive =
          href === '/'
            ? currentPath === '/'
            : currentPath.startsWith(href);
        return (
          <li>
            <a
              href={href}
              class={[
                'block px-3 py-2.5 rounded text-sm font-medium transition-colors duration-150',
                isActive
                  ? 'bg-blue-light text-blue-DEFAULT'
                  : 'text-mid hover:bg-off hover:text-dark',
              ].join(' ')}
              aria-current={isActive ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        );
      })}
      <li class="pt-2 border-t border-border mt-2">
        <a
          href="/contacto"
          class="block w-full text-center bg-dark text-white text-sm font-medium px-5 py-2.5 rounded hover:bg-mid transition-colors"
        >
          Contáctenos
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn      = document.getElementById('menu-btn')!;
  const menu     = document.getElementById('mobile-menu')!;
  const iconOpen  = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  btn.addEventListener('click', () => {
    const isOpen = menu.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(isOpen));
    iconOpen.classList.toggle('hidden', isOpen);
    iconClose.classList.toggle('hidden', !isOpen);
  });
</script>
