---
import type { Project } from '../../data/projects';

interface Props {
  project: Project;
}
const { project } = Astro.props;
---

<article class="flex flex-col sm:flex-row gap-4 py-6 border-b border-border last:border-none hover:bg-off transition-colors duration-100 px-2 -mx-2 rounded">

  <!-- Thumbnail -->
  <div class="shrink-0 w-full sm:w-24 h-28 sm:h-16 bg-off border border-border rounded flex items-center justify-center text-[10px] font-mono text-muted uppercase tracking-wider">
    {project.image
      ? <img src={project.image} alt={project.name} class="w-full h-full object-cover rounded" loading="lazy" />
      : 'IMG'
    }
  </div>

  <!-- Info -->
  <div class="flex-1 min-w-0">
    <div class="flex flex-wrap items-start justify-between gap-2 mb-1">
      <h3 class="text-sm font-semibold text-dark leading-snug">{project.name}</h3>
      <span class="font-mono text-[11px] text-muted shrink-0">{project.year}</span>
    </div>
    <p class="text-xs text-muted mb-1">{project.client}</p>
    <div class="flex flex-wrap gap-2 mt-2">
      <span class="font-mono text-[11px] px-2.5 py-1 bg-blue-light text-blue-DEFAULT rounded">
        {project.category}
      </span>
      <span class="text-xs text-muted self-center">{project.location}</span>
    </div>
  </div>
</article>
