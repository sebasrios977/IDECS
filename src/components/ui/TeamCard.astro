---
interface Props {
  initials: string;
  name:     string;
  role:     string;
  bio:      string;
}
const { initials, name, role, bio } = Astro.props;
---

<article class="border border-border rounded-lg p-6 md:p-7 hover:border-blue-DEFAULT transition-colors duration-150">
  <div
    class="w-14 h-14 rounded-full bg-blue-light flex items-center justify-center font-mono text-base text-blue-DEFAULT mb-4"
    aria-hidden="true"
  >
    {initials}
  </div>
  <h3 class="text-base font-semibold text-dark mb-0.5">{name}</h3>
  <p class="text-xs text-blue-DEFAULT mb-3">{role}</p>
  <p class="text-sm text-muted leading-relaxed">{bio}</p>
</article>
