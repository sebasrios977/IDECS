---
import BaseLayout    from '../layouts/BaseLayout.astro';
import Navbar        from '../components/layout/Navbar.astro';
import Footer        from '../components/layout/Footer.astro';
import SectionLabel  from '../components/ui/SectionLabel.astro';
import ProjectCard   from '../components/ui/ProjectCard.astro';
import CtaBand       from '../components/sections/CtaBand.astro';
import { PROJECTS, PROJECT_CATEGORIES } from '../data/projects';

const categories = ['Todos', ...PROJECT_CATEGORIES];
---

<BaseLayout
  title="Proyectos"
  description="Portafolio de proyectos ejecutados en obra civil, estructuras metálicas, metalmecánica industrial e infraestructura en Colombia."
>
  <Navbar />

  <main id="main-content" class="pt-16 md:pt-[68px]">

    <!-- Page header -->
    <header class="border-b border-border py-14 md:py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
          <SectionLabel text="portafolio" />
          <h1 class="font-head text-display-lg font-black text-dark mt-1">Proyectos</h1>
        </div>
        <p class="text-sm text-muted max-w-sm">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ut enim ad minim
          veniam, quis nostrud exercitation ullamco laboris.
        </p>
      </div>
    </header>

    <!-- Filter bar -->
    <div class="border-b border-border bg-off sticky top-16 md:top-[68px] z-40">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex flex-wrap gap-2" role="toolbar" aria-label="Filtrar proyectos">
        {categories.map((cat) => (
          <button
            type="button"
            data-filter={cat}
            class={[
              'filter-btn text-xs sm:text-sm px-3.5 py-1.5 rounded border transition-colors duration-150',
              cat === 'Todos'
                ? 'bg-dark text-white border-dark'
                : 'bg-transparent text-muted border-border hover:border-mid hover:text-dark',
            ].join(' ')}
            aria-pressed={cat === 'Todos' ? 'true' : 'false'}
          >
            {cat}
          </button>
        ))}
      </div>
    </div>

    <!-- Project list -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-14" aria-label="Lista de proyectos">
      <div id="projects-count" class="font-mono text-xs text-muted mb-6">
        Mostrando {PROJECTS.length} de {PROJECTS.length} proyectos
      </div>

      <div id="project-list" class="divide-y divide-border">
        {PROJECTS.map((project) => (
          <div data-category={project.category}>
            <ProjectCard project={project} />
          </div>
        ))}
      </div>

      <!-- Empty state -->
      <p id="empty-state" class="hidden text-center text-muted py-16 text-sm">
        No hay proyectos en esta categoría.
      </p>
    </section>

    <CtaBand
      title="¿Tiene un proyecto similar en mente?"
      subtitle="Cuéntenos sobre su reto de ingeniería y lo ayudamos."
      cta="Contáctenos"
    />
  </main>

  <Footer />
</BaseLayout>

<script>
  const buttons    = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards      = document.querySelectorAll<HTMLElement>('[data-category]');
  const countEl    = document.getElementById('projects-count')!;
  const emptyState = document.getElementById('empty-state')!;
  const total      = cards.length;

  function applyFilter(filter: string) {
    let visible = 0;

    cards.forEach((card) => {
      const show = filter === 'Todos' || card.dataset.category === filter;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    countEl.textContent = `Mostrando ${visible} de ${total} proyectos`;
    emptyState.classList.toggle('hidden', visible > 0);

    buttons.forEach((btn) => {
      const active = btn.dataset.filter === filter;
      btn.className = btn.className
        .replace(/bg-dark text-white border-dark|bg-transparent text-muted border-border hover:border-mid hover:text-dark/g, '')
        .trim();
      btn.classList.add(
        ...(active
          ? ['bg-dark', 'text-white', 'border-dark']
          : ['bg-transparent', 'text-muted', 'border-border', 'hover:border-mid', 'hover:text-dark']),
      );
      btn.setAttribute('aria-pressed', String(active));
    });
  }

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => applyFilter(btn.dataset.filter ?? 'Todos'));
  });
</script>
